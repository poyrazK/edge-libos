## 2. Host skeleton (Rust, illustrative)

```rust
use wasmtime::*;

struct Kernel {
    memory: Option<Memory>,
    fds: FdTable,          // fd -> Resource (File | Socket | Epoll | Pipe | EventFd)
    mm: LinearAllocator,   // §1.2 anon-mmap allocator
    clock: ClockState,
    // wasi delegation context lives here too
}

fn add_to_linker(linker: &mut Linker<Kernel>) -> Result<()> {
    linker.func_new_async(
        "kernel", "syscall",
        FuncType::new(/* 7×I64 */ std::iter::repeat(ValType::I64).take(7), [ValType::I64]),
        |mut caller, params, results| Box::new(async move {
            let nr = params[0].unwrap_i64() as u32;
            let a  = [params[1].unwrap_i64(), params[2].unwrap_i64(), params[3].unwrap_i64(),
                      params[4].unwrap_i64(), params[5].unwrap_i64(), params[6].unwrap_i64()];
            let ret = dispatch(&mut caller, nr, a).await; // returns i64, -errno on error
            results[0] = Val::I64(ret);
            Ok(())
        }),
    )?;
    Ok(())
}

async fn dispatch(caller: &mut Caller<'_, Kernel>, nr: u32, a: [i64;6]) -> i64 {
    match nr {
        NR_WRITE        => sys_write(caller, a).await,
        NR_READ         => sys_read(caller, a).await,
        NR_EPOLL_WAIT   => sys_epoll_wait(caller, a).await, // .await suspends the fiber
        NR_MMAP         => sys_mmap(caller, a),
        // ...
        _ => -ENOSYS,
    }
}
```

Guest-memory helper every syscall uses:

```rust
fn guest_slice_mut<'a>(c: &'a mut Caller<'_, Kernel>, ptr: i64, len: i64) -> Result<&'a mut [u8], i64> {
    let mem = c.data().memory.ok_or(-EFAULT)?;
    let (base, _store) = mem.data_and_store_mut(c);
    let (p, l) = (ptr as usize, len as usize);
    base.get_mut(p..p.checked_add(l).ok_or(-EFAULT)?).ok_or(-EFAULT).map_err(|_| -EFAULT)
}
```

